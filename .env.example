# Lovable Cloud / Supabase (publishable values — safe to expose to the client)
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
VITE_SUPABASE_PROJECT_ID="your-project-id"

# Server-side mirror (same values, used by server functions)
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
SUPABASE_PROJECT_ID="your-project-id"

# Set to "true" only on Lovable hosting (*.lovable.app or Lovable-managed
# custom domains). On Vercel the Google sign-in button is hidden because the
# Lovable OAuth broker (/~oauth/*) is not available there.
VITE_ENABLE_GOOGLE_AUTH="false"

# Secrets (set in Vercel Project Settings → Environment Variables, never commit)
# LOVABLE_API_KEY=
# SUPABASE_SERVICE_ROLE_KEY=