# Supabase (publishable values — safe to expose to the client)
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
VITE_SUPABASE_PROJECT_ID="your-project-id"

# Server-side mirror (same values, used by server functions)
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
SUPABASE_PROJECT_ID="your-project-id"

# Keep disabled until Supabase OAuth is configured for the current deployment.
VITE_ENABLE_GOOGLE_AUTH="false"
VITE_ENABLE_FOUNDER_MODE="false"

# Founder/dev owner tooling. Keep disabled unless running a trusted local/dev task.
FOUNDER_EMAIL="dnainform@gmail.com"
ENABLE_DEV_OWNER_TOOLS="false"

# Secrets (set in Vercel Project Settings → Environment Variables, never commit)
# SUPABASE_SERVICE_ROLE_KEY=
