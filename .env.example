# Supabase (publishable values — safe to expose to the client)
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
VITE_SUPABASE_PROJECT_ID="your-project-id"

# Server-side mirror (same values, used by server functions)
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
SUPABASE_PROJECT_ID="your-project-id"

# Keep disabled until Supabase OAuth is configured for the current deployment.
VITE_ENABLE_GOOGLE_AUTH="false"
VITE_ENABLE_FOUNDER_MODE="false"

# Founder/dev owner tooling. Keep disabled unless running a trusted local/dev task.
FOUNDER_EMAIL="dnainform@gmail.com"
ENABLE_DEV_OWNER_TOOLS="false"
VITE_ENABLE_DEV_OWNER_TOOLS="false"

# AI and voice provider selectors. Local Sense works without keys; OpenAI is optional.
AI_PROVIDER="disabled"
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL="gpt-4o-mini"
AI_MODEL_ROUTER_ENABLED="false"
AI_AUDIT_LOGGING_ENABLED="true"
STT_PROVIDER="browser"
TTS_PROVIDER="disabled"
# Server STT/TTS via OpenAI (requires use_voice permission):
# STT_PROVIDER="openai"
# TTS_PROVIDER="openai"
# ElevenLabs — single Sense voice (optional override; defaults to warm voice per language)
# ELEVENLABS_VOICE_SENSE=
# TTS_PROVIDER=elevenlabs
# ELEVENLABS_API_KEY=
# OPENAI_TTS_MODEL="tts-1-hd"
# High-quality multilingual TTS via ElevenLabs:
# TTS_PROVIDER="elevenlabs"
# ELEVENLABS_API_KEY=
# ELEVENLABS_MODEL="eleven_multilingual_v2"
# ELEVENLABS_OUTPUT_FORMAT="mp3_44100_128"
# ELEVENLABS_VOICE_NOVA=
# ELEVENLABS_VOICE_VERA=

# Invitation email (Resend). Keep disabled until domain and API key are configured.
ENABLE_INVITATION_EMAIL="false"
# RESEND_API_KEY=
# RESEND_FROM_EMAIL="1inow <onboarding@yourdomain.com>"

# Billing (Stripe). Disabled until checkout/webhooks are implemented.
ENABLE_STRIPE="false"
BILLING_PROVIDER="disabled"
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID=
# VITE_STRIPE_PUBLISHABLE_KEY=
# VITE_APP_URL="https://1inow.com"

# Analytics. Disabled until privacy/consent UX is approved.
ANALYTICS_PROVIDER="disabled"
VITE_ANALYTICS_PROVIDER="disabled"
# VITE_PLAUSIBLE_DOMAIN=
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST="https://us.i.posthog.com"
# VITE_GA4_MEASUREMENT_ID=

# Monitoring. Disabled until error reporting is wired.
MONITORING_PROVIDER="disabled"
VITE_MONITORING_PROVIDER="disabled"
# SENTRY_DSN=
# VITE_SENTRY_DSN=

# Secrets (set in Vercel Project Settings → Environment Variables, never commit)
# SUPABASE_SERVICE_ROLE_KEY=
